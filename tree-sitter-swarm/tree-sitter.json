{
  "grammars": [
    {
      "name": "swarm",
      "camelcase": "Swarm",
      "scope": "source.swarm",
      "path": ".",
      "file-types": [
        "sw"
      ],
      "highlights": "queries/highlights.scm",
      "injection-regex": "swarm"
    }
  ],
  "metadata": {
    "version": "0.1.0",
    "license": "MIT",
    "description": "Tree-sitter grammar for Swarm Language (.sw)",
    "links": {
      "repository": "https://github.com/tree-sitter/tree-sitter-swarm"
    }
  },
  "bindings": {
    "c": true,
    "go": true,
    "node": true,
    "python": true,
    "rust": true,
    "swift": true
  }
}
